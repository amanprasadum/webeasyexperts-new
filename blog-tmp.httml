            </div>
          </div>

          <!-- Related posts -->
          <div class="wbeasy-blog-pg-related-widget">
            <div class="wbeasy-blog-pg-related-head">
              <i class="bi bi-journals"></i>
              <span>Related Posts</span>
            </div>
            <a href="#" class="wbeasy-blog-pg-related-item">
              <div class="wbeasy-blog-pg-related-thumb" style="background:#FFF0F0;"><i class="bi bi-shop" style="color:#E53935"></i></div>
              <div>
                <div class="wbeasy-blog-pg-related-item-title">How to Build a High-Converting Shopify Store</div>
                <div class="wbeasy-blog-pg-related-item-meta">5 min read · eCommerce</div>
              </div>
            </a>
            <a href="#" class="wbeasy-blog-pg-related-item">
              <div class="wbeasy-blog-pg-related-thumb" style="background:#F0F7FF;"><i class="bi bi-search" style="color:#2563EB"></i></div>
              <div>
                <div class="wbeasy-blog-pg-related-item-title">SEO Tips Every Small Business Website Needs</div>
                <div class="wbeasy-blog-pg-related-item-meta">6 min read · SEO</div>
              </div>
            </a>
            <a href="#" class="wbeasy-blog-pg-related-item">
              <div class="wbeasy-blog-pg-related-thumb" style="background:#F0FFF5;"><i class="bi bi-phone" style="color:#16A34A"></i></div>
              <div>
                <div class="wbeasy-blog-pg-related-item-title">Why Responsive Design is Non-Negotiable in 2025</div>
                <div class="wbeasy-blog-pg-related-item-meta">4 min read · Web Design</div>
              </div>
            </a>
          </div>

        </div><!-- /sidebar -->
        </div><!-- /sidebar-sticky -->
